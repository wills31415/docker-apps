# =============================================================================
# Cluster minecraft-test — bac à sable Creative pour tests in-game
# =============================================================================
# Tourne en parallèle de minecraft-server. Partage le même modpack via copie
# automatique depuis ../minecraft-server/shared/data/coupaing-craft-initial.mrpack
# au démarrage (cf. pre-up.sh).
#
# Accès LAN uniquement — pas de NAT/PAT routeur. Pas de Dynmap, pas de RCON
# exposé (utiliser `docker exec minecraft_test rcon-cli "<cmd>"` depuis l'hôte).
# =============================================================================

TYPE=MODRINTH
VERSION=1.20.1
FABRIC_LOADER_VERSION=0.19.2

MODRINTH_MODPACK=/data/coupaing-craft-initial.mrpack
MODRINTH_LOADER=fabric
MODRINTH_PROJECTS=
MODRINTH_FORCE_SYNCHRONIZE=true

# Reprise du même filtre que prod (mods client-only embarqués qu'il ne faut
# pas charger côté serveur). À garder synchronisé avec minecraft-server/config/.env.
MODRINTH_EXCLUDE_FILES=animatica,BetterGrassify,bettermounthud,cape-provider,container-tooltips,continuity,controlify,CrashAssistant,cwb-fabric,dynamic-fps,e4mc,entityculling,entity_model_features,entity_texture_features,fabrishot,fastquit,ImmediatelyFast,iris-fabric,Jade,journeymap,lambdynamiclights,language-reload,main-menu-credits,mixintrace,modmenu,morechathistory,moreculling,neotooltipfix,optigui,paginatedadvancements,polytone,puzzle-fabric,reeses-sodium-options,rrlsFabric,skyboxify,sodium,zoomify

MEMORY=4G
USE_AIKAR_FLAGS=false

MOTD="§eCoupaingCraft§8 - §bTest World (Creative)"
SERVER_PORT=25565
RCON_PORT=25575

DIFFICULTY=peaceful
MODE=creative
MAX_PLAYERS=4
VIEW_DISTANCE=12
SIMULATION_DISTANCE=8
ONLINE_MODE=true
PVP=false
ALLOW_FLIGHT=true
ALLOW_NETHER=true
ENABLE_COMMAND_BLOCK=true
SPAWN_ANIMALS=true
SPAWN_MONSTERS=false
SPAWN_NPCS=true
GENERATE_STRUCTURES=true

LEVEL=test_world
LEVEL_TYPE=default

# OPs perso : voir .env.local (gitignored)

ENABLE_WHITELIST=false

ENABLE_RCON=true
RCON_PASSWORD=changeme-rcon-test

REMOVE_OLD_MODS=true
TZ=UTC
