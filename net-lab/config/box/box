#!/usr/bin/env bash
# ============================================================
#  box — CLI interne du routeur net-lab
#
#  Sous-commandes :
#    box apply      relit box.conf et (re)construit les règles iptables
#                   (NAT/DNAT + pare-feu DMZ + mode egress). Idempotent.
#    box status     affiche l'état courant (config + règles + compteurs)
#    box conntrack  affiche la table de suivi de connexions (NAT en direct)
#
#  N'est PAS destiné à un usage direct : il est piloté depuis
#  l'hôte par box-apply.sh / box-status.sh (l'« IHM »).
#
#  Entrées :
#    /etc/net-lab/box.conf  (monté ro)  → PUBLIC_IP, *_SUBNET, DMZ_HOST,
#                                          FORWARDS, EGRESS_VIA_BOX
#    $HOSTMAP  (env, "nom=ip;nom=ip")   → résolution nom de machine → IP
# ============================================================
set -euo pipefail

BOX_CONF="${BOX_CONF:-/etc/net-lab/box.conf}"

die() { echo "❌  box: $*" >&2; exit 1; }

load_conf() {
    [ -f "$BOX_CONF" ] || die "config introuvable : $BOX_CONF"
    # shellcheck source=/dev/null
    source "$BOX_CONF"
    : "${PUBLIC_IP:?PUBLIC_IP manquant}" "${LAN_SUBNET:?}" "${DMZ_SUBNET:?}"
}

# Résout un nom de machine en IP via $HOSTMAP ("gateway=192.168.1.10;nas=...")
resolve() {
    local name="$1" pair
    for pair in ${HOSTMAP//;/ }; do
        [ "${pair%%=*}" = "$name" ] && { echo "${pair#*=}"; return 0; }
    done
    return 1
}

cmd_apply() {
    load_conf
    sysctl -w net.ipv4.ip_forward=1 >/dev/null 2>&1 || true

    # ── Remise à zéro de NOS tables (namespace réseau de la box) ──
    iptables -t nat -F
    iptables -F FORWARD
    iptables -P FORWARD DROP

    # ── Pare-feu inter-segments (la matrice de la DMZ) ───────────
    # Le trafic retour est toujours autorisé.
    iptables -A FORWARD -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT
    # DMZ → LAN : INTERDIT (raison d'être de la DMZ).
    iptables -A FORWARD -s "$DMZ_SUBNET" -d "$LAN_SUBNET" -j DROP
    # Connexions entrantes redirigées (DNAT) : autorisées.
    iptables -A FORWARD -m conntrack --ctstate DNAT -j ACCEPT
    # LAN → DMZ : autorisé (le LAN est de confiance).
    iptables -A FORWARD -s "$LAN_SUBNET" -d "$DMZ_SUBNET" -j ACCEPT
    # LAN/DMZ → reste (WAN) : autorisé.
    iptables -A FORWARD -s "$LAN_SUBNET" -j ACCEPT
    iptables -A FORWARD -s "$DMZ_SUBNET" -j ACCEPT

    # ── Redirections de ports (DNAT sur l'IP publique) ───────────
    local rule proto pub tgt tport tip n=0
    for rule in "${FORWARDS[@]:-}"; do
        [ -z "$rule" ] && continue
        IFS=':' read -r proto pub tgt tport <<< "$rule"
        if ! tip="$(resolve "$tgt")"; then
            echo "⚠️  redirection ignorée (machine inconnue : $tgt) : $rule" >&2
            continue
        fi
        iptables -t nat -A PREROUTING -d "$PUBLIC_IP" -p "$proto" \
            --dport "$pub" -j DNAT --to-destination "$tip:$tport"
        n=$((n + 1))
    done

    # ── DMZ host : tout le trafic entrant NON déjà redirigé → cet hôte ──
    # Sémantique réelle du « DMZ host » d'une box grand public. Ajouté APRÈS
    # les redirections explicites, qui gardent donc la priorité (1re règle
    # DNAT qui matche l'emporte). Port d'origine conservé (pas de :port).
    local dmz_ip=""
    if [ -n "${DMZ_HOST:-}" ]; then
        if dmz_ip="$(resolve "$DMZ_HOST")"; then
            iptables -t nat -A PREROUTING -d "$PUBLIC_IP" -p tcp -j DNAT --to-destination "$dmz_ip"
            iptables -t nat -A PREROUTING -d "$PUBLIC_IP" -p udp -j DNAT --to-destination "$dmz_ip"
        else
            echo "⚠️  DMZ_HOST inconnu (ignoré) : $DMZ_HOST" >&2
            dmz_ip=""
        fi
    fi

    # ── NAT sortant : dépend du mode d'egress ────────────────────
    if [ "${EGRESS_VIA_BOX:-0}" = "1" ]; then
        # Box = passerelle par défaut des nodes : on ne masque QUE vers
        # l'extérieur (WAN/Internet). En interne (LAN↔DMZ et DNAT entrant)
        # la source réelle est préservée — le retour repasse par la box.
        # NB : iptables-nft refuse plusieurs `! -d` dans une seule règle →
        # on saute MASQUERADE en RETURN quand la destination reste interne.
        iptables -t nat -A POSTROUTING -s "$LAN_SUBNET" -d "$LAN_SUBNET" -j RETURN
        iptables -t nat -A POSTROUTING -s "$LAN_SUBNET" -d "$DMZ_SUBNET" -j RETURN
        iptables -t nat -A POSTROUTING -s "$LAN_SUBNET" -j MASQUERADE
        iptables -t nat -A POSTROUTING -s "$DMZ_SUBNET" -d "$LAN_SUBNET" -j RETURN
        iptables -t nat -A POSTROUTING -s "$DMZ_SUBNET" -d "$DMZ_SUBNET" -j RETURN
        iptables -t nat -A POSTROUTING -s "$DMZ_SUBNET" -j MASQUERADE
    else
        # Egress par Docker : on masque le trafic que la box pousse vers
        # LAN/DMZ → chemin de retour propre, sans toucher aux routes des nodes.
        iptables -t nat -A POSTROUTING -d "$LAN_SUBNET" -j MASQUERADE
        iptables -t nat -A POSTROUTING -d "$DMZ_SUBNET" -j MASQUERADE
    fi

    local mode="egress=Docker"
    [ "${EGRESS_VIA_BOX:-0}" = "1" ] && mode="egress=box (passerelle)"
    echo "✅  box: règles appliquées ($n redirection(s), DMZ host=${DMZ_HOST:-aucun}, $mode)"
}

cmd_status() {
    load_conf
    echo "╔══════════════════════════════════════════════════════════╗"
    echo "║  BOX net-lab — état courant                              ║"
    echo "╠══════════════════════════════════════════════════════════╣"
    printf "  IP publique : %s\n" "$PUBLIC_IP"
    printf "  WAN : %-18s LAN : %-18s\n" "${WAN_SUBNET:-?}" "$LAN_SUBNET"
    printf "  DMZ : %-18s hôte DMZ : %s\n" "$DMZ_SUBNET" "${DMZ_HOST:-aucun}"
    local egress="Docker (egress direct, source masquée en interne)"
    [ "${EGRESS_VIA_BOX:-0}" = "1" ] && egress="box = passerelle par défaut (source réelle préservée)"
    printf "  Mode egress : %s\n" "$egress"
    [ -n "${DMZ_HOST:-}" ] && printf "  DMZ host    : tout le trafic entrant restant → %s\n" "$DMZ_HOST"
    echo "  ── Baux statiques ───────────────────────────────────────"
    local l
    for l in "${LEASES[@]:-}"; do [ -n "$l" ] && printf "    %s\n" "$l"; done
    echo "  ── Redirections (proto:public → cible:port) ─────────────"
    local rule proto pub tgt tport tip
    for rule in "${FORWARDS[@]:-}"; do
        [ -z "$rule" ] && continue
        IFS=':' read -r proto pub tgt tport <<< "$rule"
        tip="$(resolve "$tgt" || echo '???')"
        printf "    %s/%s → %s (%s):%s\n" "$proto" "$pub" "$tgt" "$tip" "$tport"
    done
    echo "  ── iptables nat (actif) ─────────────────────────────────"
    iptables -t nat -S | sed 's/^/    /'
    echo "  ── Pare-feu FORWARD (règles + compteurs paquets/octets) ─"
    # -v -n : les compteurs rendent VISIBLE le pare-feu au travail
    # (ex. combien de paquets DMZ→LAN ont été DROP).
    iptables -L FORWARD -v -n | sed 's/^/    /'
    echo "  ── Connexions suivies (NAT en direct) : box conntrack ───"
    echo "╚══════════════════════════════════════════════════════════╝"
}

cmd_conntrack() {
    echo "── Table de suivi de connexions (NAT en direct) ──────────────"
    echo "  original (src→dst) puis reply : voir DNAT / MASQUERADE traduire."
    echo ""
    if command -v conntrack >/dev/null 2>&1; then
        conntrack -L 2>/dev/null || echo "  (table vide pour l'instant — génère du trafic puis relance)"
    else
        echo "  ⚠️  conntrack non installé dans la box (rebuild : da restart net-lab --build)"
    fi
}

case "${1:-}" in
    apply)     cmd_apply ;;
    status)    cmd_status ;;
    conntrack) cmd_conntrack ;;
    *) die "usage : box {apply|status|conntrack}" ;;
esac
