# =============================================================================
# Configuration du serveur Minecraft
# =============================================================================
# Modifier les valeurs ci-dessous selon vos besoins puis lancer :
#   da restart minecraft-server
#
# Documentation complète de l'image :
#   https://docker-minecraft-server.readthedocs.io
# =============================================================================


# =============================================================================
# TYPE DE SERVEUR ET VERSION
# =============================================================================

# Type de serveur : VANILLA | PAPER | FABRIC | FORGE | SPIGOT | BUKKIT | QUILT | MODRINTH
# Pour déployer un modpack Modrinth (.mrpack), utiliser TYPE=MODRINTH ; le loader
# (fabric/forge/quilt) et la version Minecraft sont alors dérivés du modpack.
TYPE=MODRINTH

# Version de Minecraft. Exemples : LATEST, 1.21.4, 1.20.1
# Doit correspondre à la version du modpack si un modpack est configuré.
VERSION=1.21.11

# Version du loader Fabric. Laisser vide pour la dernière version disponible.
FABRIC_LOADER_VERSION=0.19.2


# =============================================================================
# MODPACK MODRINTH
# =============================================================================
# Pour installer un modpack depuis Modrinth, renseigner l'une de ces valeurs :
#   - Slug du projet (ex: cobblemon-fabric)
#   - URL de la page Modrinth (ex: https://modrinth.com/modpack/cobblemon-fabric)
#   - Chemin vers un fichier .mrpack dans le container (ex: /data/mon-pack.mrpack)

# Modpack "coupaing-craft" — actuellement en mode .mrpack local le temps que
# le projet Modrinth sorte de "Under review". Une fois approuvé, basculer sur
#   MODRINTH_MODPACK=coupaing-craft
#   MODRINTH_VERSION_TYPE=release
#   MODRINTH_FORCE_SYNCHRONIZE=true
# (workflow géré par ./sync-pack.sh — voir SYNC.md).
MODRINTH_MODPACK=/data/coupaing-craft-initial.mrpack

# Forcer le loader Fabric lors de la résolution du modpack.
MODRINTH_LOADER=fabric

# Filtrer par type de version du modpack : release | beta | alpha
# MODRINTH_VERSION_TYPE=release

# Mods Modrinth supplémentaires à ajouter par-dessus le modpack.
# Liste de slugs séparés par des virgules (ex: fabric-api,lithium,sodium).
# Tous ces mods ont env={client:unsupported, server:required} → la ModrinthApp
# des joueurs ne les installera pas, ce qui cause un feedback loop si on les
# met dans le pack uploadé. Solution : injection côté serveur uniquement.
# Depuis l'architecture "profil master" (commit 552abd3), les 6 mods server-only
# sont directement inclus dans le .mrpack avec env={client:unsupported, server:required}.
# Le bridge MODRINTH_PROJECTS n'est plus nécessaire et causerait un double-download.
MODRINTH_PROJECTS=
# Forcer itzg à re-synchroniser les mods avec le manifest du pack à chaque démarrage
# (supprime les mods en trop, ré-installe ceux qui manquent).
MODRINTH_FORCE_SYNCHRONIZE=true

# Exclure des mods incompatibles côté serveur (noms partiels de fichiers).
# Le pack déclare beaucoup de mods comme client+server, mais la plupart sont
# en réalité purement client (rendu, HUD, options) et feraient crasher le
# serveur. On ne garde que les mods serveur utiles : fabric-api, lithium,
# ferritecore, polymer, graves, debugify, NoChatReports, libs, etc.
MODRINTH_EXCLUDE_FILES=animatica,BetterGrassify,bettermounthud,cape-provider,container-tooltips,continuity,controlify,CrashAssistant,cwb-fabric,dynamic-fps,e4mc,entityculling,entity_model_features,entity_texture_features,fabrishot,fastquit,ImmediatelyFast,iris-fabric,Jade,journeymap,lambdynamiclights,language-reload,main-menu-credits,mixintrace,modmenu,morechathistory,moreculling,neotooltipfix,optigui,paginatedadvancements,polytone,puzzle-fabric,reeses-sodium-options,rrlsFabric,skyboxify,sodium,zoomify

# Ignorer des fichiers temporaires supprimés par des mods pour éviter
# qu'ils soient réinstallés en boucle à chaque redémarrage.
# MODRINTH_IGNORE_MISSING_FILES=


# =============================================================================
# MÉMOIRE JVM
# =============================================================================
# MEMORY alloue la même valeur pour -Xms et -Xmx.
# 4G est un minimum raisonnable pour un serveur Fabric moddé.
# Augmenter si le serveur utilise beaucoup de mods ou accueille plus de joueurs.
MEMORY=5G

# Pour un contrôle plus fin, décommenter et utiliser INIT_MEMORY / MAX_MEMORY
# à la place de MEMORY (les deux ne sont pas combinables).
# INIT_MEMORY=2G
# MAX_MEMORY=6G

# Flags d'optimisation JVM d'Aikar — recommandés historiquement pour les serveurs Minecraft.
# https://docs.papermc.io/paper/aikars-flags
# Désactivé : un flag G1GC inclus est removed dans Java 21 récent (image itzg/minecraft-server
# avril 2026), provoquait un crash JVM silencieux au boot (exit -1, aucun log Java visible).
# Java 21 a déjà G1GC bien tuné par défaut, l'impact perf est négligeable.
USE_AIKAR_FLAGS=false


# =============================================================================
# IDENTITÉ DU SERVEUR
# =============================================================================

# Message affiché dans la liste des serveurs du client Minecraft.
# Supporte les codes couleur Minecraft (ex: \u00a76 = doré).
MOTD="Serveur Minecraft"

# Port du serveur Minecraft (connexion des joueurs).
SERVER_PORT=25565

# URL vers une image 64x64 PNG affichée comme icône du serveur.
# ICON=https://example.com/icon.png


# =============================================================================
# PARAMÈTRES DE JEU
# =============================================================================

# peaceful | easy | normal | hard
DIFFICULTY=normal

# survival | creative | adventure | spectator
MODE=survival

# Nombre maximum de joueurs simultanés.
MAX_PLAYERS=10

# Distance de rendu en chunks (1 chunk = 16 blocs). Réduire si lag.
VIEW_DISTANCE=18

# Distance de simulation en chunks. Les entités hors de cette distance
# ne sont pas mises à jour (économise du CPU).
SIMULATION_DISTANCE=12

# true = les joueurs doivent posséder un compte Minecraft officiel.
# false = permet les comptes crackés (déconseillé en ligne).
ONLINE_MODE=true

# Combat entre joueurs.
PVP=true

# Vol en mode survie (certains mods nécessitent true).
ALLOW_FLIGHT=false

# Accès au Nether.
ALLOW_NETHER=true

# Activer les blocs de commande.
ENABLE_COMMAND_BLOCK=false

# Spawn des créatures.
SPAWN_ANIMALS=true
SPAWN_MONSTERS=true
SPAWN_NPCS=true

# Génération des structures (villages, temples, etc.).
GENERATE_STRUCTURES=true


# =============================================================================
# MONDE
# =============================================================================

# Nom du dossier du monde dans /data.
LEVEL=world

# Type de terrain : default | flat | largeBiomes | amplified | single_biome_surface
LEVEL_TYPE=default

# Seed de génération du monde. Laisser vide pour un seed aléatoire.
# Utiliser des guillemets pour les seeds négatifs (ex: "-123456").
# SEED=


# =============================================================================
# GESTION DES JOUEURS
# =============================================================================

# Opérateurs (admins) — noms Minecraft ou UUID, séparés par des virgules.
# OPS=Joueur1,Joueur2

# Liste blanche — noms Minecraft ou UUID, séparés par des virgules.
# WHITELIST=Joueur1,Joueur2

# Activer l'application de la whitelist (seuls les joueurs listés peuvent jouer).
ENABLE_WHITELIST=false


# =============================================================================
# RCON — Console d'administration à distance
# =============================================================================

# Activer RCON (nécessaire pour rcon-cli et les commandes depuis l'hôte).
ENABLE_RCON=true

# Mot de passe RCON. Changer cette valeur avant d'exposer le serveur !
RCON_PASSWORD=changeme-rcon

# Port RCON (exposé uniquement sur localhost par le docker-compose).
RCON_PORT=25575


# =============================================================================
# DYNMAP — Carte web temps réel du monde
# =============================================================================
# Port web exposé sur l'hôte. Le mod Dynmap écoute sur 8123 dans le container ;
# docker-compose remappe vers DYNMAP_PORT côté hôte.
# Ouvrable en NAT/PAT sur le routeur pour un accès Internet.
# Pas d'authentification par défaut — utiliser un reverse proxy si besoin,
# ou activer webpassword-protected dans shared/data/config/dynmap/configuration.txt.
DYNMAP_PORT=25566


# =============================================================================
# RESOURCE PACK
# =============================================================================
# URL d'un resource pack envoyé automatiquement aux joueurs à la connexion.
# RESOURCE_PACK=https://example.com/pack.zip
# RESOURCE_PACK_SHA1=
# RESOURCE_PACK_ENFORCE=false


# =============================================================================
# MODS SUPPLÉMENTAIRES (hors modpack)
# =============================================================================
# URLs directes de fichiers .jar, séparées par des virgules.
# MODS=https://example.com/mod1.jar,https://example.com/mod2.jar

# Fichier texte listant des URLs de mods (une par ligne, # = commentaire).
# MODS_FILE=/data/mods.txt

# Supprimer les anciens mods avant d'installer les nouveaux à chaque démarrage.
REMOVE_OLD_MODS=true


# =============================================================================
# DIVERS
# =============================================================================

# Fuseau horaire pour les horodatages dans les logs du serveur.
TZ=UTC
